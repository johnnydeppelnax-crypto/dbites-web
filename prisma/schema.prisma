generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Product {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String
  price       Float
  image       String
  category    String
  featured    Boolean  @default(false)
  rating      Float    @default(4.5)
  reviewCount Int      @default(0)
  weight      String
  ingredients String
  inStock     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Order {
  id        String   @id @default(cuid())
  email     String
  name      String
  phone     String?
  address   String
  city      String
  state     String?
  zipCode   String
  total     Float
  status    String   @default("pending")
  items     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
